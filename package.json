{
  "name": "dscode",
  "version": "0.1.1",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron": "electron .",
    "electron:dev": "DSCODE_DEV_MODE=1 electron .",
    "electron:debug": "DSCODE_DEV_MODE=1 DSCODE_DEV_TOOLS=1 electron .",
    "dist:mac": "next build && electron-builder --mac",
    "dist:win": "next build && electron-builder --win",
    "dist:all": "next build && electron-builder -mw"
  },
  "build": {
    "appId": "kr.hs.duksoo.dscode",
    "productName": "DS Code",
    "asar": false,
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      ".next/**/*",
      "next.config.ts",
      "next-env.d.ts",
      "tsconfig.json",
      "public/**/*",
      "package.json",
      ".env.production",
      "node_modules/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "mac": {
      "category": "public.app-category.education",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
      "identity": "Yonghun Kim (3WPS7QNZV5)",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true,
      "icon": "build/icon.png"
    },
    "dmg": {
      "title": "DS Code ${version}"
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.159",
    "@anthropic-ai/claude-agent-sdk-darwin-arm64": "0.3.159",
    "@anthropic-ai/claude-agent-sdk-darwin-x64": "0.3.159",
    "@anthropic-ai/claude-agent-sdk-win32-arm64": "0.3.159",
    "@anthropic-ai/claude-agent-sdk-win32-x64": "0.3.159",
    "@anthropic-ai/sdk": "^0.98.0",
    "@monaco-editor/react": "^4.7.0",
    "lucide-react": "^0.460.0",
    "next": "16.2.6",
    "next-auth": "5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "optionalDependencies": {
    "@next/swc-darwin-arm64": "16.2.6",
    "@next/swc-darwin-x64": "16.2.6",
    "@next/swc-win32-x64-msvc": "16.2.6",
    "@next/swc-win32-arm64-msvc": "16.2.6"
  },
  "pnpm": {
    "supportedArchitectures": {
      "os": ["darwin", "win32"],
      "cpu": ["x64", "arm64"]
    }
  }
}
